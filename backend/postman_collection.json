{
  "info": {
    "name": "English Learning App API",
    "_postman_id": "english-learning-app-kbtu-2026",
    "description": "Complete API collection for the English Learning App — Angular + Django project. Base URL: http://localhost:8000/api\n\nAuth: all endpoints except /auth/login/ and /auth/register/ require the Bearer token in the Authorization header. After login, copy the 'access' token and set it as {{token}} in the collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Paste the access token here after login"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "Paste the refresh token here after login"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securepass123\",\n  \"confirmPassword\": \"securepass123\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 2,\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"displayName\": \"john_doe\",\n  \"bio\": \"\",\n  \"avatar\": \"\",\n  \"joinedAt\": \"2026-04-22T10:00:00.000000Z\"\n}"
            },
            {
              "name": "400 Bad Request — username taken",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"username\": [\"This username is already taken.\"]\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo1234\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout/", "host": ["{{base_url}}"], "path": ["auth", "logout", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"detail\": \"Successfully logged out.\"\n}"
            },
            {
              "name": "400 Bad Request — already used",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"detail\": \"Token is invalid or already expired.\"\n}"
            }
          ]
        },
        {
