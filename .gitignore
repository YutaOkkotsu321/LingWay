backend/celerybeat-schedule
backend/celerybeat.pid

# Migrations: keep the files (they belong in VCS), but nothing to ignore here.
# Pytest / coverage
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/

