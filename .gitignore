# ═════════════════════════════════════════════════════════════════════════════
# Backend (Python / Django)
# ═════════════════════════════════════════════════════════════════════════════

# Byte-compiled / optimized / DLL files
backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class
backend/**/*.so

# Virtual environments
backend/venv/
backend/env/
backend/.venv/

# Django
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/static_collected/
